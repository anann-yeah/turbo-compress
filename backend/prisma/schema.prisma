datasource db {
  provider = "postgresql"
  // REMOVE 'url' and ADD 'adapter'
  adapter  = "pg" 
}

generator client {
  provider = "prisma-client-js"
  // This ensures it works on your Alpine Docker image
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}
model User {
  id    String @id @default(uuid())
  email String @unique
  name  String? // Add this line!
  isPro Boolean @default(false)
  files File[]
}

model File {
  id             String     @id @default(uuid())
  filename       String
  s3Key          String
  originalSize   Int
  compressedSize Int
  status         FileStatus @default(PENDING)
  userId         String
  user           User       @relation(fields: [userId], references: [id])
  createdAt      DateTime   @default(now())
}

enum FileStatus {
  PENDING
  COMPRESSING
  UPLOADING
  SCANNING
  SAFE
  INFECTED
}