{
  "compilerOptions": {
    "isolatedModules": true,
    "target": "es2022",
    "module": "CommonJS",
    "rootDir": "./",
    "outDir": "./dist",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["jest", "node"], // ADD THIS LINE
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "prisma/**/*","jest.config.cjs"]
}