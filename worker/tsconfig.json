{
  "compilerOptions": {
    "target": "ESNext",
    // Use "5.0" instead of "6.0" if you are on an older sub-version of TS 5
    "ignoreDeprecations": "5.0", 
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "outDir": "./dist"
  }
}